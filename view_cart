<?php
if (!empty($_SESSION['cart'])) {
    $ids = implode(',', array_keys($_SESSION['cart']));
    $query = "SELECT product_id, name, price FROM products WHERE product_id IN ($ids)";
    $result = $conn->query($query);

    echo "<table><tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr>";

    $grand_total = 0;
    while ($row = $result->fetch_assoc()) {
        $pid = $row['product_id'];
        $quantity = $_SESSION['cart'][$pid];
        $total = $row['price'] * $quantity;
        $grand_total += $total;

        echo "<tr>
                <td>{$row['name']}</td>
                <td>₹{$row['price']}</td>
                <td>$quantity</td>
                <td>₹$total</td>
              </tr>";
    }
    echo "<tr><td colspan='3'><strong>Grand Total</strong></td><td><strong>₹$grand_total</strong></td></tr>";
    echo "</table>";
} else {
    echo "<p style='text-align:center;'>Your cart is empty.</p>";
}
$conn->close();
?>
</body>
</html>
